# Database - Get your connection string from https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-example-123.region.aws.neon.tech/dbname?sslmode=require

# Clerk Authentication - Get your keys from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# Upstash Redis (for rate limiting) - Required for production
# Get from Vercel → Storage → Redis or https://console.upstash.com
# In development: optional (will use in-memory fallback)
# In production: REQUIRED for rate limiting to work
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here
